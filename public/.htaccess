# Infinity Energy — static SPA on Apache/LiteSpeed (Hostinger)
# 1) Canonical host: force HTTPS + www  (Fix 2 — stops apex/www signal split)
# 2) Serve prerendered <route>.html for clean URLs (no trailing slash)
# 3) SPA fallback to index.html for all client-side routes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # --- Canonical host: HTTPS + www, in a single 301 hop ---
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^ https://www.infinityenergy.xyz%{REQUEST_URI} [R=301,L,NE]

  # --- Real files and directories are served as-is (assets, etc.) ---
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # --- Prerendered page?  e.g. /about -> /about.html ---
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+?)/?$ /$1.html [L]

  # --- SPA fallback: everything else boots the React app ---
  RewriteRule ^ /index.html [L]
</IfModule>
